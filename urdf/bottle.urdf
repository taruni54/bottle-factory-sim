<?xml version='1.0' encoding='utf-8'?>
<robot name='bottle'>
  <link name='bottle_base'>
    <visual>
      <geometry>
        <cylinder radius='0.05' length='0.2'/>
      </geometry>
      <material name='bottle_color'>
        <color rgba='0.0 0.5 1.0 1.0' />
      </material>
    </visual>
  </link>
  <joint name='base_to_top' type='fixed'>
    <parent link='bottle_base'/>
    <child link='bottle_top'/> 
    <origin xyz='0 0 0.1' rpy='0 0 0'/>
  </joint>

  <link name='bottle_top'>
    <visual>
      <geometry>
        <cylinder radius='0.04' length='0.1'/>
      </geometry>
      <material name='bottle_color'>
        <color rgba='0.0 0.5 1.0 1.0' />
      </material>
    </visual>
  </link>
</robot>